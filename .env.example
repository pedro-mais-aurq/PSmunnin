# ============================================================
# PSmunnin
# Environment Variables Template
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=LeadHunter AI
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# ------------------------------------------------------------
# API
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=leadhunter
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_URL=

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# ------------------------------------------------------------
# Email
# ------------------------------------------------------------
RESEND_API_KEY=
SENDGRID_API_KEY=
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_REGION=sa-east-1

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
SECRET_KEY=
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO